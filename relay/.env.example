# Relay — environment variables
# Copy to .env.local and fill in your key.

# --- Database (Neon / Vercel Postgres integration sets these automatically) ---
DATABASE_URL=postgres://...            # pooled — used at runtime
DATABASE_URL_UNPOOLED=postgres://...   # direct — used for migrations

# --- Auth.js (NextAuth v5) ---
AUTH_SECRET=                # generate: openssl rand -base64 33
AUTH_URL=http://localhost:8882
# Google sign-in (open to any account). Create an OAuth client in Google Cloud;
# authorized redirect URI: http://localhost:8882/api/auth/callback/google (+ your prod URL).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional: override the seeded credentials user (defaults below). Run `npm run db:seed`.
# SEED_USER_EMAIL=connor@mindmaven.com
# SEED_USER_PASSWORD=relay-demo-2026

# Primary provider — used for BOTH transcription (Whisper) and drafting (GPT).
OPENAI_API_KEY=sk-...

# Optional drafting fallback. If OpenAI drafting fails (or OPENAI_API_KEY is
# unset), Relay falls back to Anthropic Claude for the email draft.
# Transcription always uses OpenAI Whisper (no Anthropic equivalent).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: require a shared secret on the /api/ingest webhook (x-relay-secret header
# or ?secret= query param). Leave unset to keep the webhook open for local testing.
# RELAY_INGEST_SECRET=some-long-random-string

# Optional model overrides (sensible defaults are used if unset)
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_TRANSCRIBE_LANGUAGE=en   # default: en (English). ISO-639-1 code.
# OPENAI_DRAFT_MODEL=gpt-4o
# ANTHROPIC_DRAFT_MODEL=claude-sonnet-4-6
